{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CronPilot",
  "version": "1.1.1",
  "identifier": "com.cronpilot.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CronPilot",
        "width": 960,
        "height": 660,
        "minWidth": 700,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lifedever/CronPilot/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCNEFFQjk1MTZGNjUwOUMKUldTY1VQWVdsZXRLMjdHVzB6NWx6OFE4RHFpcmtkeDNvRWlVa0xmVWRNQm1lc2tKZVFyZzUzSWgK"
    }
  }
}
