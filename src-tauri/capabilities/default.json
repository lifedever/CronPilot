{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "shell:allow-execute",
    "shell:allow-open",
    "notification:default",
    "store:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart"
  ]
}
